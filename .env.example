# ═══════════════════════════════════════
# Company OS - Environment Configuration
# ═══════════════════════════════════════
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ── Server ──
PORT=3001
NODE_ENV=development

# ── Auth (REQUIRED) ──
JWT_SECRET=your-secret-here

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Database ──
# SQLite (default — no config needed):
DB_PATH=./data/company-os.db

# PostgreSQL (production — set this to use PG instead):
# DATABASE_URL=postgres://user:pass@localhost:5432/companyos

# ── LLM / AI Engine ──
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
DEFAULT_MODEL=gpt-4

# ── SMTP (Outbound Email) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── IMAP (Inbound Email Polling) ──
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
IMAP_POLL_INTERVAL_MS=60000

# ── Logging ──
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ── PostgreSQL (Docker Compose) ──
POSTGRES_USER=companyos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=companyos

# ── Frontend (web/.env.local) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
